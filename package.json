{
  "name": "nestjs-mastra-mcp-gateway",
  "version": "0.1.0",
  "description": "Production-style MCP gateway built with NestJS and Mastra. Demonstrates HTTP transport, pluggable auth, request-scoped context propagation, and external-API tool patterns. Ships a Wikipedia tool surface as the example.",
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo",
    "build": "nest build",
    "build:prod": "NODE_ENV=production nest build",
    "start": "nest build && node ./dist/main.js",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint --quiet ./src --config eslint.config.js",
    "prettier:fix": "prettier -w .",
    "type-check": "tsc --noEmit --project tsconfig.spec.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@mastra/core": "^1.2.0",
    "@mastra/mcp": "^1.0.0",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "axios": "^1.7.9",
    "express": "^5.2.1",
    "jose": "^5.9.6",
    "redis": "^5.9.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.2.0",
    "zod": "3.25.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@types/express": "^5.0.6",
    "@types/jest": "29.5.0",
    "@types/node": "^22.18.12",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n": "^17.15.1",
    "eslint-plugin-unicorn": "^56.0.1",
    "globals": "^15.13.0",
    "jest": "^29.5.0",
    "nock": "^13.5.5",
    "prettier": "^3.7.4",
    "rimraf": "^6.0.1",
    "ts-jest": "29.0.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "./tsconfig.spec.json" }]
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@src/(.*)$": "<rootDir>/$1"
    }
  }
}
