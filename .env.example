# ==============================================================================
# Local development. Copy to `.env` and adjust as needed.
# ==============================================================================

NODE_ENV=development
PORT=3000

# ── Auth mode ─────────────────────────────────────────────────────────────────
# `none` — no auth required. Tools are publicly callable. Default for demo.
# `jwt`  — require Bearer JWT validated via OIDC JWKS. Set the JWT_* vars below.
AUTH_MODE=none

# ── (Optional) Service-level API key ──────────────────────────────────────────
# When set, every /mcp/* request must also present `x-api-key: <value>`.
# Leave unset to disable the API-key check.
# MCP_API_KEY=local-dev-key

# ── (AUTH_MODE=jwt) OIDC JWT validation ───────────────────────────────────────
# Required only when AUTH_MODE=jwt. Works with any OIDC-compliant IdP
# (Auth0, Keycloak, Cognito, Okta, …) that publishes a JWKS over HTTPS.
# JWT_ISSUER=https://YOUR_TENANT.auth0.com/
# JWT_AUDIENCE=https://api.example.com
# JWT_JWKS_URI=https://YOUR_TENANT.auth0.com/.well-known/jwks.json

# ── Redis (used to cache Wikipedia API responses) ─────────────────────────────
# `docker compose up` provisions this automatically. For bare-metal `npm run
# start:dev`, run `docker run -d -p 6379:6379 redis:7-alpine` first.
REDIS_URL=redis://localhost:6379
